{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/codex-governance/jira-work-item.schema.json",
  "title": "Normalized Jira work item",
  "type": "object",
  "required": ["format_version", "governance_status", "profile", "source", "scope", "git_range", "decision", "roadmap_impact", "links", "handoff"],
  "properties": {
    "format_version": { "const": 1 },
    "governance_status": { "enum": ["ready", "in-implementation", "pending-review", "pending-verification", "source-drift-blocked", "blocked", "closed"] },
    "profile": { "const": "generic" },
    "source": {
      "type": "object",
      "required": ["story_key", "story_url", "subtask_key", "subtask_url", "captured_at", "story_updated_at", "subtask_updated_at", "story_description_digest", "story_acceptance_criteria_digest", "subtask_description_digest", "subtask_acceptance_criteria_digest"],
      "properties": {
        "mode": { "enum": ["live-jira", "offline-export"] },
        "provider": { "enum": ["jira", "offline-export"], "deprecated": true },
        "story_key": { "type": "string", "pattern": "^[A-Z][A-Z0-9]+-[0-9]+$" },
        "story_url": { "type": "string", "format": "uri" },
        "subtask_key": { "type": "string", "pattern": "^[A-Z][A-Z0-9]+-[0-9]+$" },
        "subtask_url": { "type": "string", "format": "uri" },
        "captured_at": { "type": "string", "format": "date-time" },
        "story_updated_at": { "type": "string", "format": "date-time" },
        "subtask_updated_at": { "type": "string", "format": "date-time" },
        "story_description_digest": { "$ref": "#/$defs/digest" },
        "story_acceptance_criteria_digest": { "$ref": "#/$defs/digest" },
        "subtask_description_digest": { "$ref": "#/$defs/digest" },
        "subtask_acceptance_criteria_digest": { "$ref": "#/$defs/digest" }
      },
      "anyOf": [
        { "required": ["mode"] },
        { "required": ["provider"] }
      ],
      "additionalProperties": false
    },
    "scope": {
      "type": "object",
      "required": ["phase", "change_class", "allowed_paths", "non_goals", "technical_acceptance_criteria", "validation_plan", "file_classification", "review_budget"],
      "properties": {
        "phase": { "type": "string", "minLength": 1 },
        "change_class": { "enum": ["trivial", "standard", "high-risk"] },
        "allowed_paths": { "$ref": "#/$defs/string_list" },
        "non_goals": { "$ref": "#/$defs/string_list" },
        "technical_acceptance_criteria": { "$ref": "#/$defs/string_list" },
        "validation_plan": { "$ref": "#/$defs/string_list" },
        "file_classification": {
          "type": "object",
          "required": ["generated_paths", "lockfile_paths"],
          "properties": {
            "generated_paths": { "type": "array", "items": { "type": "string" } },
            "lockfile_paths": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "review_budget": {
          "type": "object",
          "required": ["max_changed_files", "max_changed_lines", "max_components"],
          "properties": {
            "max_changed_files": { "type": "integer", "minimum": 1 },
            "max_changed_lines": { "type": "integer", "minimum": 1 },
            "max_components": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "git_range": {
      "type": "object",
      "required": ["base_sha", "head_sha"],
      "properties": {
        "base_sha": { "type": "string", "pattern": "^[a-f0-9]{7,64}$" },
        "head_sha": { "type": "string", "pattern": "^[a-f0-9]{7,64}$" }
      },
      "additionalProperties": false
    },
    "decision": {
      "type": "object",
      "required": ["adr"],
      "properties": {
        "adr": { "type": "string", "pattern": "^(docs/decisions/.+\\.md|No ADR needed: .+)$" },
        "adr_preflight_pending": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "roadmap_impact": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": { "enum": ["required", "not-applicable"] },
        "roadmap_id": { "type": "string", "minLength": 1 },
        "canonical_path": { "type": "string", "minLength": 1 },
        "phase": { "type": "string", "minLength": 1 },
        "transition": { "enum": ["start", "block", "resume", "complete"] },
        "reason": { "type": "string", "minLength": 10, "maxLength": 240 }
      },
      "oneOf": [
        { "properties": { "mode": { "const": "required" } }, "required": ["roadmap_id", "canonical_path", "phase", "transition"], "not": { "required": ["reason"] } },
        { "properties": { "mode": { "const": "not-applicable" } }, "required": ["reason"], "not": { "anyOf": [{ "required": ["roadmap_id"] }, { "required": ["canonical_path"] }, { "required": ["phase"] }, { "required": ["transition"] }] } }
      ],
      "additionalProperties": false
    },
    "links": {
      "type": "object",
      "required": ["pull_request", "ci_run", "review_exception", "agent_exception"],
      "properties": {
        "pull_request": { "type": ["string", "null"], "format": "uri" },
        "ci_run": { "type": ["string", "null"], "format": "uri" },
        "review_exception": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "required": ["jira_reference", "reason", "approver", "review_plan", "approved_at", "containment_plan"],
              "properties": {
                "jira_reference": { "type": "string", "format": "uri" },
                "reason": { "type": "string", "minLength": 1 },
                "approver": { "type": "string", "minLength": 1 },
                "review_plan": { "$ref": "#/$defs/string_list" },
                "approved_at": { "type": "string", "format": "date-time" },
                "containment_plan": { "type": ["string", "null"] }
              },
              "additionalProperties": false
            }
          ]
        },
        "agent_exception": {
          "oneOf": [
            { "type": "null" },
            { "type": "object", "required": ["jira_reference", "reason", "approver", "approved_at"], "properties": { "jira_reference": { "type": "string", "format": "uri" }, "reason": { "type": "string", "minLength": 1 }, "approver": { "type": "string", "minLength": 1 }, "approved_at": { "type": "string", "format": "date-time" } }, "additionalProperties": false }
          ]
        }
      },
      "additionalProperties": false
    },
    "handoff": {
      "type": "object",
      "required": ["status", "completed_work", "blocker", "next_action"],
      "properties": {
        "status": { "type": "string", "minLength": 1 },
        "completed_work": { "type": "string", "minLength": 1 },
        "blocker": { "type": ["string", "null"] },
        "next_action": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "string_list": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  },
  "additionalProperties": false
}
